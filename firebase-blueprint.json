{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A handcrafted accessory or craft item.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "slug": { "type": "string", "description": "URL-friendly identifier" },
        "category": { "type": "string", "description": "Category ID" },
        "subcategory": { "type": "string", "description": "Subcategory name" },
        "price": { "type": "number", "description": "Price in NGN" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Base64 encoded image strings" },
        "description": { "type": "string", "description": "Product details" },
        "stockStatus": { "type": "string", "enum": ["in_stock", "low_stock", "out_of_stock"] },
        "stockCount": { "type": "number", "description": "Current inventory level" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isNew": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "category", "price", "images"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category grouping.",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "subcategories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["label"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the customer" },
        "items": { "type": "array", "description": "List of products purchased" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "paid", "failed"] },
        "shippingAddress": { "type": "object" },
        "receiptImage": { "type": "string", "description": "Base64 encoded receipt if manual payment" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role data.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "phoneNumber": { "type": "string" },
        "cart": { "type": "array", "description": "Live cart sync data" }
      },
      "required": ["email", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Internal admin alerts for form submissions.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["order", "training", "event", "contact", "newsletter"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "data": { "type": "object", "description": "The raw form data" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Store for all products" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Admin notification feed" }
  }
}
