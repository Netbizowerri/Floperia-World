# ============================================================
# FLOPERIA CLASSIC WORLD — PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env (never commit .env to git)
# For Vercel: set these in the Vercel dashboard → Settings → Environment Variables
# For cPanel: set these in the Node.js App Manager or create a .env file in the app root
# ============================================================

# --- EMAIL SERVICE (Resend) ---
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_LIVE_RESEND_KEY

# --- ADMIN EMAIL ---
# Receives order and contact notifications
ADMIN_EMAIL=netbiz0925@gmail.com

# --- PAYSTACK (Public Key - safe to expose in browser) ---
# Get from https://dashboard.paystack.com/#/settings/developers
# Use live key for production, test key for staging
VITE_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PAYSTACK_PUBLIC_KEY

# --- FIREBASE (Already embedded in firebase-applet-config.json) ---
# Firebase Web SDK config is public by design (protected by Firestore Security Rules)
# No Firebase config keys needed here unless you move away from firebase-applet-config.json
